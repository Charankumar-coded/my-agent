# AI Agent Backend Configuration

# Server settings
HOST=0.0.0.0
PORT=8001
DEBUG=False
LOG_LEVEL=info

# CORS settings
ALLOWED_ORIGINS=["http://localhost:8000", "http://localhost:3000"]

# Optional: AI/LLM Integration
# OpenAI API Key (if using GPT-4 or GPT-3.5)
# OPENAI_API_KEY=your_key_here

# Anthropic API Key (if using Claude)
# ANTHROPIC_API_KEY=your_key_here

# Model selection
# MODEL_PROVIDER=openai  # or anthropic
# MODEL_NAME=gpt-4  # or claude-3-opus-20240229

# Optional: Database configuration for persistence
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent
# REDIS_URL=redis://localhost:6379

# Optional: Feature flags
# ENABLE_CACHING=True
# ENABLE_METRICS=True
# ENABLE_RATE_LIMITING=False
